# Disable HuggingFace Hub integration in Gradio.
# We do not use HuggingFace models or OAuth, and disabling this prevents
# unnecessary imports and avoids compatibility issues.
GRADIO_DISABLE_HUGGINGFACE_HUB=1

# API key for your LLM provider
OPENAI_API_KEY=your_api_key_here

# Optional: override the model
MODEL=gpt-4o
